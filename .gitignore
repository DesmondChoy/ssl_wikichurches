# macOS
.DS_Store

# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Tool caches
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Coverage reports
.coverage
htmlcov/

# Virtual environments
.venv

# Dataset files
dataset/

# Runtime outputs (large binary artifacts only)
outputs/cache/
outputs/checkpoints/

# Experiment outputs (but allow scripts and configs)
experiments/outputs/
experiments/results/
experiments/logs/

.playwright-mcp

# Slide generation intermediate images (embedded in .pptx)
outputs/slides/*.png

# Node.js (pptxgenjs for slide generation)
experiments/scripts/node_modules/
experiments/scripts/package*.json

# Task files
tasks/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
